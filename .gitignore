*.py[cod]
*$py.class
*.so

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Project specific
.pytest_cache/
.coverage
htmlcov/

# Dependencies
dist/
build/
*.egg-info/